# 後端環境變數範本
# 複製此檔案為 .env，填入實際值
# ⚠️  .env 已加入 .gitignore，絕對不可 commit

# ── Flask ──
FLASK_ENV=development
FLASK_DEBUG=true
PORT=5000
SECRET_KEY=your_flask_secret_key_here

# ── MongoDB（仿 LibreChat MONGO_URI 格式）──
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/travelwise?retryWrites=true&w=majority
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# ── Redis（景點 API 快取）──
REDIS_URL=redis://localhost:6379/0

# ── Firebase Admin SDK（ID Token 驗證）──
# 本機：下載 JSON 放到 backend/ 並用檔案路徑
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase_service_account.json
FIREBASE_PROJECT_ID=your_firebase_project_id
# 雲端部署（Render）：改用此變數，貼入整份 service account JSON（單行字串）。
# 有設這個就會優先於上面的 PATH。
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# ── CORS：正式環境允許的前端來源（Vercel 網域），逗號分隔 ──
# 例：CORS_ORIGINS=https://travel-wise.vercel.app
# CORS_ORIGINS=

# ── 認證模式（雲端部署預設 false）──
# false=正式驗證 Firebase token；true=跳過驗證、共用 test-user-001
FLASK_TESTING=false

# ── OpenAI ──
OPENAI_API_KEY=sk-...your_key_here
OPENAI_MODEL=gpt-4o

# ── OpenTripMap API（免費景點資料）──
OPENTRIPMAP_API_KEY=your_opentripmap_api_key_here

# ── Open-Meteo（免費，不需 Key）──
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ── 快取設定 ──
PLACES_CACHE_TTL_SECONDS=86400   # 24 小時
WEATHER_CACHE_TTL_SECONDS=3600   # 1 小時

# ── 航班資訊（RapidAPI → AviationStack）──
# 從 https://rapidapi.com/aviationstack 取得
RAPIDAPI_KEY=your_rapidapi_key_here
